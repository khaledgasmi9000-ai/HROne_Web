{% extends 'Gestion Administrative/layout.html.twig' %}
{% set activeTab = 'outils' %}

{% block title %}Outils{% endblock %}

{% block employee_content %}

<!-- KPI (generic) -->
<div class="kpi-grid">
    <div class="kpi-card">
        <span class="kpi-title">KPI 1</span>
        <h2 class="kpi-value">--</h2>
    </div>
    <div class="kpi-card">
        <span class="kpi-title">KPI 2</span>
        <h2 class="kpi-value">--</h2>
    </div>
    <div class="kpi-card">
        <span class="kpi-title">KPI 3</span>
        <h2 class="kpi-value">--</h2>
    </div>
</div>

<!-- Table Section -->
<div class="table-section">

    <div class="table-header">

        <!-- LEFT: ordering (checkboxes) -->
        <div class="table-controls-left">
            <label class="checkbox-control">
                <input type="checkbox" id="orderUsers" {{ orderUsers ? 'checked' : '' }}>
                <span>Par nombre d’utilisateurs</span>
            </label>

            <label class="checkbox-control">
                <input type="checkbox" id="orderTime" {{ orderTime ? 'checked' : '' }}>
                <span>Par temps moyen</span>
            </label>

            <div class="search-box">
                <input 
                    type="text" 
                    id="toolSearch" 
                    value="{{ app.request.get('search') }}"
                    placeholder="Rechercher un outil..." 
                />

                <button id="searchBtnTool" class="btn secondary with-icon">
                    <span class="icon">🔍</span>
                </button>
            </div>
        </div>

        <!-- RIGHT: buttons -->
        <div class="table-controls-right">
            <button class="btn secondary with-icon">
                <span class="icon">⬇</span>
                Export
            </button>

            <button class="btn secondary with-icon">
                <span class="icon">⬆</span>
                Import
            </button>

            <button class="btn primary with-icon">
                <span class="icon">＋</span>
                Ajouter
            </button>
        </div>

    </div>

    <!-- TABLE -->
    <div class="table-container fixed">
        <table>
            <thead>
                <tr>
                    <th style="display:none;">ID</th>
                    <th>Nom</th>
                    <th>Temps moyen</th>
                    <th>Nombre d'utilisateurs</th>
                    <th></th> {# Actions column #}
                </tr>
            </thead>

            <tbody>
                {% for tool in tools %}
                    <tr data-id="{{ tool.id }}">
                        <td style="display:none;">{{ tool.id }}</td>

                        <td class="tool-name">{{ tool.name }}</td>
                        <td>{{ tool.avgTime }} h</td>
                        <td>{{ tool.users }}</td>

                        <td class="actions-cell">
                            {% include 'Gestion Administrative/components/row_actions.html.twig' with {
                                employeeId: tool.id
                            } %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Aucun outil trouvé</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- PAGINATION -->
    {% include 'Gestion Administrative/components/pagination.html.twig' with {
        currentPage: currentPage,
        totalPages: totalPages,
        rowsPerPage: rowsPerPage,
        totalEmployees: totalTools,
        currentCount: tools|length
    } %}

</div>
{% endblock %}