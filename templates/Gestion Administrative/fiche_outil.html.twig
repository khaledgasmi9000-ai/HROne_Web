{% extends 'base_back.html.twig' %}

{% block title %}Fiche Outil{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/Gestion Administrative/fiche_outil.css') }}">
{% endblock %}

{% block body %}
<div class="fiche-container">

    <!-- HEADER -->
    <div class="tool-header">
        <h1>Fiche Outil</h1>
        <div class="tool-meta">
            <p><strong>Nom :</strong> {{ tool.nomOutil }}</p>
            <p><strong>Catégorie :</strong> {{ tool.categorie.nom ?? 'Non catégorisé' }}</p>
            <p><strong>Coût mensuel :</strong> {{ tool.monthlyCost }} TND</p>
        </div>
    </div>

    <!-- GLOBAL STATS -->
    <div class="tool-stats">
        <div class="stat">
            <span>Temps moyen</span>
            <strong>{{ stats.avgTime }} h</strong>
        </div>
        <div class="stat">
            <span>Utilisateurs</span>
            <strong>{{ stats.users }}</strong>
        </div>
        <div class="stat">
            <span>Coût total</span>
            <strong>{{ stats.costTotal }} TND</strong>
        </div>
    </div>

    <!-- TOP USERS -->
    <div class="section">
        <h2>Top utilisateurs</h2>
        <ul>
            {% for user in topUsers %}
                <li>{{ user.nom }} → {{ user.temps }} h</li>
            {% else %}
                <li>Aucune donnée</li>
            {% endfor %}
        </ul>
    </div>

    <!-- DISTRIBUTION -->
    <div class="section">
        <h2>Répartition par département</h2>
        <ul>
            {% for dept in departements %}
                <li>{{ dept.name }} → {{ dept.percent }}%</li>
            {% else %}
                <li>Aucune donnée</li>
            {% endfor %}
        </ul>
    </div>

    <!-- EMPLOYEES TABLE -->
    <div class="section">
        <h2>Employés utilisant cet outil</h2>

        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Temps (h)</th>
                    <th>Salaire</th>
                    <th>Coût estimé</th>
                </tr>
            </thead>
            <tbody>
                {% for emp in employees %}
                    <tr>
                        <td>{{ emp.nom ?? '' }} </td>
                        <td>{{ emp.temps }} h</td>
                        <td>{{ emp.salaire ?? '-' }}</td>
                        <td>{{ emp.cout > 0 ? emp.cout ~ ' TND' : '-' }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4">Aucun employé trouvé</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- SUMMARY -->
    <div class="section summary">
        <h2>Résumé</h2>
        <p>{{ summary}}</p>
    </div>

</div>
{% endblock %}