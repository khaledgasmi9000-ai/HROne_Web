{% extends 'base.html.twig' %}

{% block title %}Fiche Outil{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/Gestion Administrative/fiche_outil.css') }}">
{% endblock %}

{% block body %}
<div class="fiche-container">

    <!-- HEADER -->
    <div class="tool-header">
        <h1>Fiche Outil</h1>
        <div class="tool-meta">
            <p><strong>Nom :</strong> Chrome</p>
            <p><strong>Catégorie :</strong> Navigateur</p>
            <p><strong>Coût mensuel :</strong> 15,00 TND</p>
        </div>
    </div>

    <!-- GLOBAL STATS -->
    <div class="tool-stats">
        <div class="stat">
            <span>Temps moyen</span>
            <strong>134 h</strong>
        </div>
        <div class="stat">
            <span>Utilisateurs</span>
            <strong>51</strong>
        </div>
        <div class="stat">
            <span>Coût total</span>
            <strong>765 TND</strong>
        </div>
    </div>

    <!-- TOP USERS -->
    <div class="section">
        <h2>Top utilisateurs</h2>
        <ul>
            <li>Khaled → 240h</li>
            <li>Ahmed → 180h</li>
            <li>Sara → 150h</li>
        </ul>
    </div>

    <!-- DISTRIBUTION -->
    <div class="section">
        <h2>Répartition par département</h2>
        <ul>
            <li>IT → 60%</li>
            <li>RH → 25%</li>
            <li>Finance → 15%</li>
        </ul>
    </div>

    <!-- EMPLOYEES TABLE -->
    <div class="section">
        <h2>Employés utilisant cet outil</h2>

        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Temps (h)</th>
                    <th>Salaire</th>
                    <th>Coût estimé</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Khaled</td>
                    <td>240</td>
                    <td>1500</td>
                    <td>120</td>
                </tr>
                <tr>
                    <td>Ahmed</td>
                    <td>180</td>
                    <td>1200</td>
                    <td>90</td>
                </tr>
                <tr>
                    <td>Sara</td>
                    <td>150</td>
                    <td>1000</td>
                    <td>75</td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- SUMMARY -->
    <div class="section summary">
        <h2>Résumé</h2>
        <p>
            Outil fortement utilisé par le département IT.
            Coût global élevé mais justifié par usage intensif.
            Possibilité d’optimisation des licences.
        </p>
    </div>

    <!-- ACTIONS -->
    <div class="actions no-print">
        <button onclick="window.print()">Exporter PDF</button>
    </div>

</div>
{% endblock %}