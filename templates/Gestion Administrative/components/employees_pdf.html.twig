<meta charset="UTF-8">
<head>
    <style>
        body {
            font-family: DejaVu Sans, Arial, sans-serif;
            color: #2c3e50;
        }

        .page {
            border: 2px solid #2c3e50;
            padding: 20px;
            height: 100%;
            box-sizing: border-box;
        }

        .title {
            float: left;
        }

        .logo {
            float: right;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
            border: 1px solid #ccc;
        }

        th {
            background-color: #34495e;
            color: white;
            padding: 8px;
            text-align: left;
            border: 1px solid #ddd;
        }

        td {
            padding: 6px;
            border-bottom: 1px solid #ddd;
            border: 1px solid #ddd;
        }

        tr:nth-child(even) {
            background-color: #f4f6f7;
        }

        .header {
            margin-bottom: 25px; /* breathing space from table */
            width: 100%;
        }

        .header table {
            width: 100%;
            table-layout: fixed; /* IMPORTANT */
            height: 100px;
        }

        .header-left{
            width: 25%;
        }

        .header-right {
            width: 25%;
            text-align: center;
            vertical-align: middle;
        }

        .header-center {
            width: 50%;
            text-align: center;
            font-size: 18px;
            font-weight: bold;
        }

        .header-right img {
            width: 80px;
            height: auto;
            display: inline-block;
        }

        .footer {
            margin-top: 20px;
            font-size: 10px;
            text-align: center;
            color: #777;
        }
    </style>
</head>

<div class="page">
    <div class="header">
        <table width="100%">
            <tr>
                <td class="header-left">
                    <div><strong>Generated At:</strong> {{ "now"|date("d/m/Y H:i") }}</div>
                    <div><strong>Generated By:</strong> {{ user.Nom | default('') }}</div>
                </td>

                <td class="header-center">
                    Liste des employés
                </td>

                <td class="header-right">
                    <img src="{{ public_path }}/logo.png" />
                </td>
            </tr>
        </table>
    </div>

    <table width="100%">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Email</th>
                <th>Telephone</th>
                <th>CIN</th>
                <th>Date Naissance</th>
                <th>Genre</th>
                <th>Solde</th>
                <th>Salaire</th>
                <th>Heures</th>
                <th>Departement</th>
            </tr>
        </thead>
        <tbody>
            {% for emp in employees %}
                <tr>
                    <td>{{ emp.Nom }}</td>
                    <td>{{ emp.Email }}</td>
                    <td>{{ emp['Téléphone'] }}</td>
                    <td>{{ emp.CIN }}</td>
                    <td>{{ emp['Date Naissance'] }}</td>
                    <td>{{ emp.Genre }}</td>
                    <td>{{ emp['Solde Congé'] }}</td>
                    <td>{{ emp.Salaire }}</td>
                    <td>{{ emp.Heures }}</td>
                    <td>{{ emp.Departement }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

</div>