<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HR One - Connexion</title>
    <link rel="icon" type="image/png" href="/images/logo-rh.png">
    <link rel="stylesheet" href="/styles/auth-pro.css?v=2">
</head>
<body class="auth-standalone">
<main class="auth-page">
    <section class="auth-container auth-login-layout">
        <aside class="auth-panel auth-brand">
            <p class="auth-brand-tag">Plateforme RH</p>
            <h1>HR One</h1>
            <p class="auth-brand-copy">
                Connectez-vous a votre espace pour gerer les formations, la communaute et les flux RH dans une interface unique.
            </p>
            <ul class="auth-feature-list">
                <li>RH: ouverture directe sur la gestion des utilisateurs</li>
                <li>Candidat: acces cible aux offres d emploi</li>
                <li>Employe: acces aux modules front et activites</li>
            </ul>
            <div class="auth-brand-links">
                <a href="{{ path('app_register_rh') }}">Compte RH</a>
                <a href="{{ path('app_register_employee') }}">Compte employe</a>
                <a href="{{ path('app_register') }}">Compte candidat</a>
            </div>
        </aside>

        <section class="auth-panel">
            <header class="auth-panel-header">
                <p class="auth-eyebrow">Authentification</p>
                <h2>Connexion</h2>
                <p class="auth-subtitle">Entrez votre email (ou nom utilisateur) et votre mot de passe.</p>
            </header>

            <div class="auth-flash-list">
                {% if error %}
                    <div class="auth-flash error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}
                {% for message in app.flashes('success') %}
                    <div class="auth-flash success">{{ message }}</div>
                {% endfor %}
            </div>

            <form method="post" class="auth-form">
                <div class="auth-field">
                    <label for="email">Email ou Nom_Utilisateur</label>
                    <input id="email" name="email" value="{{ last_username }}" autocomplete="username" required autofocus>
                </div>

                <div class="auth-field">
                    <label for="password">Mot de passe</label>
                    <input id="password" type="password" name="password" autocomplete="current-password" required>
                </div>

                <div class="auth-field">
                    <label for="captcha_answer">Captcha</label>
                    <div class="auth-captcha-box">
                        <span class="auth-captcha-question">Resoudre: {{ captcha_question }}</span>
                        <input id="captcha_answer" name="captcha_answer" inputmode="numeric" pattern="[0-9]*" placeholder="Votre reponse" required>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="auth-action-row">
                    <button class="auth-btn-primary" type="submit">Se connecter</button>
                </div>
            </form>

            <div class="auth-separator"></div>

            <div class="auth-link-list">
                <a href="{{ path('app_register_rh') }}">Inscription RH</a>
                <a href="{{ path('app_register_employee') }}">Inscription employe</a>
                <a href="{{ path('app_register') }}">Inscription candidat</a>
            </div>
        </section>
    </section>
</main>
</body>
</html>
