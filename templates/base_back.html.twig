<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}HR One - Gestion des formations{% endblock %}</title>
    <link rel="icon" type="image/png" href="/images/logo-rh.png">
    <link rel="stylesheet" href="/styles/admin-sidebar.css?v=2">
    {% block stylesheets %}{% endblock %}
</head>
<body class="{% block body_class %}page-gestion-formations{% endblock %}">
{% set current_route = app.request.attributes.get('_route') ?? '' %}
<div class="layout">
    <aside class="sidebar">
        <div class="brand">
            <div class="logo">
                <img src="/images/logo-rh.png" alt="HR One" />
            </div>
            <div>
                <div class="brand-name">HR One</div>
                <div class="brand-sub">Espace RH</div>
            </div>
        </div>

        <nav class="nav">
            <a class="nav-link {{ current_route starts with 'app_user_' ? 'active' : '' }}" href="{{ path('app_user_module') }}">Gestion des utilisateurs</a>
            <a class="nav-link {{ current_route == 'app_rh_history' ? 'active' : '' }}" href="{{ path('app_rh_history') }}">Historique des actions</a>
            <a class="nav-link" href="#">Activity Watch</a>
            <a class="nav-link" href="#">Gestion des conges</a>
            <a class="nav-link" href="#">Gestion administrative</a>
            <a class="nav-link" href="#">Gestion des outils</a>
            <a class="nav-link" href="#">Gestion des entretiens</a>
            <a class="nav-link" href="#">Gestion des offres d'emploi</a>
            <a class="nav-link" href="#">Gestion des evenements</a>
            <a class="nav-link {{ current_route starts with 'app_admin_formation' ? 'active' : '' }}" href="{{ path('app_admin_formation_index') }}">Gestion des formations</a>
            <a class="nav-link {{ current_route starts with 'community_admin' ? 'active' : '' }}" href="{{ path('community_admin_dashboard') }}">Gestion des communautes</a>
            {% if app.user %}
                <a class="nav-link" href="{{ path('app_logout') }}">Deconnexion</a>
            {% else %}
                <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
            {% endif %}
        </nav>
    </aside>

    <main class="content">
        {% block body %}{% endblock %}
    </main>
</div>
</body>
</html>
