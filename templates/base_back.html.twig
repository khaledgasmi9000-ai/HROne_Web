<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}HR One - Gestion des formations{% endblock %}</title>
    <link rel="icon" type="image/png" href="/images/logo-rh.png">
    <link rel="stylesheet" href="/styles/admin-sidebar.css?v=3">
    {% block stylesheets %}{% endblock %}
</head>
<body class="{% block body_class %}page-gestion-formations{% endblock %}">
<div class="layout">
    {% include 'partials/rh_sidebar.html.twig' %}

    <main class="content">
        {% block body %}{% endblock %}
    </main>
</div>
</body>
{% block javascripts %}{% endblock %}
{% block importmap %}{{ importmap('app') }}{% endblock %}
</html>
