{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ evenement.Titre }}{% endblock %}

{% block body %}
<div class="page-header">
    <h1 class="page-title">✏️ Modifier l'événement</h1>
    <a href="{{ path('evenement_index') }}" class="btn btn-secondary">← Retour</a>
</div>

<div class="card form-card">
    {{ form_start(form) }}

    <div class="form-group">
        {{ form_label(form.Titre) }}
        {{ form_widget(form.Titre) }}
        {% for error in form.Titre.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.Description) }}
        {{ form_widget(form.Description) }}
        {% for error in form.Description.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.Localisation) }}
        {{ form_widget(form.Localisation) }}
        {% for error in form.Localisation.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.dateDebut) }}
        {{ form_widget(form.dateDebut) }}
        {% for error in form.dateDebut.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.dateFin) }}
        {{ form_widget(form.dateFin) }}
        {% for error in form.dateFin.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.Image) }}
        {{ form_widget(form.Image) }}
        {% for error in form.Image.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        <div class="checkbox-group">
            {{ form_widget(form.est_payant) }}
            <span class="checkbox-label">{{ form_label(form.est_payant) }}</span>
        </div>
        {% for error in form.est_payant.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.prix) }}
        {{ form_widget(form.prix) }}
        {% for error in form.prix.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.nbMax) }}
        {{ form_widget(form.nbMax) }}
        {% for error in form.nbMax.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.activites) }}
        <div class="checkbox-list">
            {{ form_widget(form.activites) }}
        </div>
        {% for error in form.activites.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div style="display:flex; gap:.8rem; margin-top:1.5rem; align-items:center;">
        {{ form_widget(form.submit, { label: 'Enregistrer les modifications' }) }}
    </div>

    {{ form_end(form) }}

    {# Formulaire de suppression séparé (HORS DU FORMULAIRE DE MODIF) #}
    <form method="post" action="{{ path('evenement_delete', {id: evenement.IDEvenement}) }}"
          onsubmit="return confirm('Supprimer définitivement cet événement ?')"
          style="margin-top: 1rem; border-top: 1px solid #eee; padding-top: 1.5rem;">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.IDEvenement) }}">
        <button type="submit" class="btn btn-danger">🗑 Supprimer définitivement cet événement</button>
    </form>
</div>
{% endblock %}
