{% extends 'base.html.twig' %}

{% block title %}Nouvel Événement{% endblock %}

{% block body %}
<div class="page-header">
    <h1 class="page-title">➕ Nouvel Événement</h1>
    <a href="{{ path('evenement_index') }}" class="btn btn-secondary">← Retour</a>
</div>

<div class="card form-card">
    {# Affichage des messages flash (alertes) #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }}" style="padding: 1rem; margin-bottom: 1rem; border-radius: 4px; background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb;">
                ⚠ {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Affichage des erreurs globales du formulaire (ex: validation des dates) #}
    {% if not form.vars.valid %}
        <div class="alert alert-danger" style="padding: 1rem; margin-bottom: 1rem; border-radius: 4px; background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb;">
            {{ form_errors(form) }}
        </div>
    {% endif %}

    {{ form_start(form) }}

    <div class="form-group">
        {{ form_label(form.Titre) }}
        {{ form_widget(form.Titre) }}
        {% for error in form.Titre.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.Description) }}
        {{ form_widget(form.Description) }}
        {% for error in form.Description.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.Localisation) }}
        {{ form_widget(form.Localisation) }}
        {% for error in form.Localisation.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.dateDebut) }}
        {{ form_widget(form.dateDebut) }}
        {% for error in form.dateDebut.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.dateFin) }}
        {{ form_widget(form.dateFin) }}
        {% for error in form.dateFin.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.Image) }}
        {{ form_widget(form.Image, { 'id': 'image-input' }) }}
        <div id="image-preview-container" style="margin-top: 10px; border: 1px dashed #ddd; border-radius: 8px; padding: 10px; text-align: center; display: none;">
            <p style="font-size: 0.8rem; color: #666; margin-bottom: 5px;">Aperçu de l'image :</p>
            <img id="image-preview" src="" alt="Aperçu" style="max-width: 100%; max-height: 200px; border-radius: 4px; object-fit: contain;">
        </div>
        {% for error in form.Image.vars.errors %}
            <p class="error-msg" style="color: #ef4444; font-size: 0.85rem; margin-top: 5px;">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        <div class="checkbox-group">
            {{ form_widget(form.est_payant) }}
            <span class="checkbox-label">{{ form_label(form.est_payant) }}</span>
        </div>
        {% for error in form.est_payant.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.prix) }}
        {{ form_widget(form.prix) }}
        {% for error in form.prix.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.nbMax) }}
        {{ form_widget(form.nbMax) }}
        {% for error in form.nbMax.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.activites) }}
        <div class="checkbox-list">
            {{ form_widget(form.activites) }}
        </div>
        {% for error in form.activites.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div style="display:flex; gap:.8rem; margin-top:1.5rem;">
        {{ form_widget(form.submit, { label: 'Créer l\'événement' }) }}
    </div>

    {{ form_end(form) }}

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const imageInput = document.getElementById('image-input');
            const previewContainer = document.getElementById('image-preview-container');
            const previewImg = document.getElementById('image-preview');

            function updatePreview() {
                const url = imageInput.value;
                if (url && url.startsWith('http')) {
                    previewImg.src = url;
                    previewContainer.style.display = 'block';
                } else {
                    previewContainer.style.display = 'none';
                }
            }

            // Mettre à jour au changement
            imageInput.addEventListener('input', updatePreview);
            updatePreview();

            // Cacher l'image si elle échoue à charger
            previewImg.onerror = function() {
                previewContainer.style.display = 'none';
            };
        });
    </script>
</div>
{% endblock %}
