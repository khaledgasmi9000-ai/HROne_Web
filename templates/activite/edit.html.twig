{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ activite.Titre }}{% endblock %}

{% block body %}
<div class="page-header">
    <h1 class="page-title">✏️ Modifier l'activité</h1>
    <a href="{{ path('activite_index') }}" class="btn btn-secondary">← Retour</a>
</div>

<div class="card form-card">
    {# form_start() ouvre la balise <form> avec la méthode POST #}
    {{ form_start(form) }}

    {# Champ Titre — pré-rempli avec la valeur actuelle #}
    <div class="form-group">
        {{ form_label(form.Titre) }}
        {{ form_widget(form.Titre) }}
        {# Affiche les erreurs de validation PHP si le titre est invalide #}
        {% for error in form.Titre.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>

    <div class="form-group">
        {{ form_label(form.Description) }}
        {{ form_widget(form.Description) }}
        {% for error in form.Description.vars.errors %}
            <p class="error-msg">⚠ {{ error.message }}</p>
        {% endfor %}
    </div>


    {# Boutons d'action : Enregistrer et Annuler #}
    <div style="display:flex; gap:.8rem; margin-top:1.5rem; flex-wrap:wrap; align-items:center;">
        {{ form_widget(form.submit, { label: 'Enregistrer les modifications' }) }}
        <a href="{{ path('activite_show', {id: activite.IDActivite}) }}" class="btn btn-secondary">Annuler</a>
    </div>

    {# form_end() ferme la balise </form> #}
    {{ form_end(form) }}

    {# Formulaire de suppression séparé avec token CSRF de sécurité (HORS DU FORMULAIRE DE MODIF) #}
    <form method="post" action="{{ path('activite_delete', {id: activite.IDActivite}) }}"
          onsubmit="return confirm('Supprimer définitivement cette activité ?')"
          style="margin-top: 1rem; border-top: 1px solid #eee; padding-top: 1.5rem;">
        {# Token CSRF : empêche les attaques de type CSRF #}
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ activite.IDActivite) }}">
        <button type="submit" class="btn btn-danger">🗑 Supprimer définitivement cette activité</button>
    </form>
</div>
{% endblock %}
