<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}HR One - Formations{% endblock %}</title>
    <link rel="icon" type="image/png" href="/images/logo-rh.png">
    <link rel="stylesheet" href="/styles/front-shared.css">
    {% block stylesheets %}{% endblock %}
</head>
<body class="{% block body_class %}page-formations{% endblock %}">
{% set current_route = app.request.attributes.get('_route') %}
<div class="app-shell">
    <header class="top-navbar">
        <nav class="top-nav">
            {% if app.user and is_granted('ROLE_CANDIDAT') and not is_granted('ROLE_EMPLOYEE') and not is_granted('ROLE_RH') %}
                <a class="nav-link {% if current_route == 'app_offres_index' %}active{% endif %}" href="{{ path('app_offres_index') }}">Offres d'emploi</a>
            {% endif %}

            {% if app.user and is_granted('ROLE_EMPLOYEE') and not is_granted('ROLE_RH') %}
                <a class="nav-link {% if current_route starts with 'community_' %}active{% endif %}" href="{{ path('community_index') }}">Communaute</a>
                <a class="nav-link {% if current_route == 'app_offres_index' %}active{% endif %}" href="{{ path('app_offres_index') }}">Offres d'emploi</a>
                <a class="nav-link {% if current_route starts with 'app_formation_' and current_route != 'app_my_participations' %}active{% endif %}" href="{{ path('app_formation_index') }}">Formations</a>
                <a class="nav-link {% if current_route == 'app_my_participations' %}active{% endif %}" href="{{ path('app_my_participations') }}">Mes participations</a>
            {% endif %}

            {% if app.user and is_granted('ROLE_RH') %}
                <a class="nav-link {% if current_route starts with 'community_admin' %}active{% endif %}" href="{{ path('community_admin_dashboard') }}">Dashboard RH</a>
                <a class="nav-link {% if current_route starts with 'app_user_' %}active{% endif %}" href="{{ path('app_user_module') }}">Utilisateurs</a>
            {% endif %}

            {% if not app.user %}
                <a class="nav-link {% if current_route == 'app_login' %}active{% endif %}" href="{{ path('app_login') }}">Connexion</a>
            {% endif %}

            {% if app.user %}
                <a class="nav-link" href="{{ path('app_logout') }}">Deconnexion</a>
            {% endif %}
        </nav>
    </header>

    <main class="page-content">
        {% block body %}{% endblock %}
    </main>
</div>
</body>
</html>
