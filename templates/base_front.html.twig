<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}HR One - Espace Employé{% endblock %}</title>
    
    {# Vos styles originaux Top Navbar #}
    <link rel="stylesheet" href="{{ asset('css/topNavbar-shared.css') }}">
    
    <style>
        /* Ajustements mineurs pour Symfony */
        body { background-color: #f1f5f9 !important; }
        .top-nav { margin-bottom: 2rem; }
        .nav-link { text-decoration: none; text-align: center; }
        .badge { font-size: 0.8rem; padding: 4px 10px; border-radius: 20px; }
        .badge-blue { background: #dbeafe; color: #1e40af; }
    </style>
</head>
<body>
    <div class="app-shell">
        <header class="top-navbar">
            <nav class="top-nav">
                <button id="btnOffres" class="nav-link" type="button" data-page="offres" data-href="#">Offres d'emploi</button>
                <button id="btnTraining" class="nav-link" type="button" data-page="formations" data-href="#">Formations</button>
                <button id="btnEvents" class="nav-link active" type="button" data-page="evenements" data-href="{{ path('app_front_evenement_index') }}">Evenements</button>
                <button id="btnParticipation" class="nav-link" type="button" data-page="participations" data-href="#">Mes participations</button>
                <button id="btnDemandeConge" class="nav-link" type="button" data-page="demande-conge" data-href="#">Demande de conge</button>
                <button id="btnCommunaute" class="nav-link" type="button" data-page="communaute" data-href="#">Communaute</button>
            </nav>
        </header>

        <main class="page-placeholder">
            <section class="interface-shell">
                {% block body %}{% endblock %}
            </section>
        </main>
    </div>

    {# Votre JS original Top Navbar #}
    <script src="{{ asset('js/topNavbar.js') }}"></script>
</body>
</html>
