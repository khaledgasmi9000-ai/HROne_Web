<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}HR One - Espace employe{% endblock %}</title>
    <link rel="stylesheet" href="/styles/front-shared.css">
    <link rel="stylesheet" href="{{ asset('css/topNavbar-shared.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body class="{% block body_class %}page-formations{% endblock %}">
{% set current_route = app.request.attributes.get('_route') %}
<div class="app-shell">
    <header class="top-navbar">
        <nav class="top-nav">
            <a class="nav-link" href="#">Offres d'emploi</a>
            <a class="nav-link {% if current_route starts with 'app_formation_' and current_route != 'app_my_participations' %}active{% endif %}" href="{{ path('app_formation_index') }}">Formations</a>
            <a class="nav-link {% if current_route starts with 'app_front_evenement_' %}active{% endif %}" href="{{ path('app_front_evenement_index') }}">Evenements</a>
            <a class="nav-link {% if current_route == 'app_my_participations' %}active{% endif %}" href="{{ path('app_my_participations') }}">Mes participations</a>
            <a class="nav-link" href="#">Demande de conge</a>
            <a class="nav-link" href="#">Communaute</a>
        </nav>
    </header>

    <main class="page-content">
        {% block body %}{% endblock %}
    </main>
</div>

    <script src="{{ asset('js/topNavbar.js') }}"></script>
</body>
</html>
