<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>HR One - Inscription RH</title>
  <link rel="stylesheet" href="{{ asset('styles.css') }}">
</head>
<body>
  <div class="page">
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="{{ path('homepage') }}">
          <div class="brand-logo">
            <img src="{{ asset('logo.png') }}" alt="HR One">
          </div>
          <div>
            <p class="brand-name">HR One</p>
            <p class="brand-sub">HR administrator onboarding</p>
          </div>
        </a>
        <div class="nav-actions">
          <a class="nav-link" href="{{ path('login') }}">Retour connexion</a>
          <a class="nav-cta" href="{{ path('signup_candidat') }}">Version candidat</a>
        </div>
      </header>

      <main class="layout">
        <section class="hero">
          <div class="hero-inner">
            <span class="eyebrow">Workspace RH</span>
            <h1>Launch HR operations with <span class="hero-highlight">control.</span></h1>
            <p class="hero-copy">
              Le parcours RH mélange image entreprise et clarté d'exécution : informations personnelles, données entreprise et présentation sérieuse.
            </p>
          </div>
        </section>

        <section class="form-side">
          <div class="form-shell">
            <div class="form-topbar">
              <span class="micro-pill">Compte RH et entreprise</span>
              <span class="mini-meta">Setup admin</span>
            </div>

            <div class="panel-head">
              <h2>Créer un compte RH</h2>
              <p>Commencez par les informations du responsable RH, puis ajoutez les données de l'entreprise.</p>
            </div>

            {# Flash messages #}
            {% for message in app.flashes('error') %}
              <div class="flash-error">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('success') %}
              <div class="flash-success">{{ message }}</div>
            {% endfor %}

            {{ form_start(form, {'attr': {'class': 'auth-form'}}) }}
              <div class="form-errors full">{{ form_errors(form) }}</div>

              <p class="section-title full">Informations RH</p>

              <div class="field{{ form.Nom_Utilisateur.vars.errors|length ? ' has-error' : '' }}">
                {{ form_label(form.Nom_Utilisateur) }}
                {{ form_widget(form.Nom_Utilisateur, {'attr': {'placeholder': 'Nom d\'utilisateur'}}) }}
                {{ form_errors(form.Nom_Utilisateur) }}
              </div>

              <div class="field{{ form.Mot_Passe.vars.errors|length ? ' has-error' : '' }}">
                {{ form_label(form.Mot_Passe) }}
                {{ form_widget(form.Mot_Passe, {'attr': {'placeholder': 'Mot de passe'}}) }}
                {{ form_errors(form.Mot_Passe) }}
              </div>

              <div class="field{{ form.Email.vars.errors|length ? ' has-error' : '' }}">
                {{ form_label(form.Email) }}
                {{ form_widget(form.Email, {'attr': {'placeholder': 'email@entreprise.com'}}) }}
                {{ form_errors(form.Email) }}
              </div>

              <div class="field{{ form.Adresse.vars.errors|length ? ' has-error' : '' }}">
                {{ form_label(form.Adresse) }}
                {{ form_widget(form.Adresse, {'attr': {'placeholder': 'Adresse'}}) }}
                {{ form_errors(form.Adresse) }}
              </div>

              <div class="field{{ form.Num_Tel.vars.errors|length ? ' has-error' : '' }}">
                {{ form_label(form.Num_Tel) }}
                {{ form_widget(form.Num_Tel, {'attr': {'placeholder': '06 00 00 00 00'}}) }}
                {{ form_errors(form.Num_Tel) }}
              </div>

              <div class="field{{ form.CIN.vars.errors|length ? ' has-error' : '' }}">
                {{ form_label(form.CIN) }}
                {{ form_widget(form.CIN, {'attr': {'placeholder': 'CIN'}}) }}
                {{ form_errors(form.CIN) }}
              </div>

              <div class="field{{ form.Date_Naissance.vars.errors|length ? ' has-error' : '' }}">
                {{ form_label(form.Date_Naissance) }}
                {{ form_widget(form.Date_Naissance) }}
                {{ form_errors(form.Date_Naissance) }}
              </div>

              <div class="field{{ form.Gender.vars.errors|length ? ' has-error' : '' }}">
                {{ form_label(form.Gender) }}
                {{ form_widget(form.Gender) }}
                {{ form_errors(form.Gender) }}
              </div>

              <p class="section-title full">Informations entreprise</p>

              <div class="field{{ form.entreprise.Nom_Entreprise.vars.errors|length ? ' has-error' : '' }}">
                {{ form_label(form.entreprise.Nom_Entreprise) }}
                {{ form_widget(form.entreprise.Nom_Entreprise, {'attr': {'placeholder': 'Nom de l\'entreprise'}}) }}
                {{ form_errors(form.entreprise.Nom_Entreprise) }}
              </div>

              <div class="field{{ form.entreprise.Reference.vars.errors|length ? ' has-error' : '' }}">
                {{ form_label(form.entreprise.Reference) }}
                {{ form_widget(form.entreprise.Reference, {'attr': {'placeholder': 'Reference'}}) }}
                {{ form_errors(form.entreprise.Reference) }}
              </div>

              <div class="actions full">
                {{ form_widget(form.submit) }}
                <a class="btn btn-outline" href="{{ path('login') }}">Retour connexion</a>
              </div>

            {{ form_end(form) }}

            <div class="trust-row">
              <span class="trust-chip">B2B friendly</span>
              <span class="trust-chip">Onboarding RH</span>
              <span class="trust-chip">Future scalable</span>
            </div>
          </div>
        </section>
      </main>
    </div>
  </div>
</body>
</html>
