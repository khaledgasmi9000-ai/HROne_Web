<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ page_title|default('HR One') }}</title>
    <link rel="icon" type="image/png" href="{{ asset('assets/navbarRH/logo.png') }}" />
    <link rel="stylesheet" href="{{ asset('assets/Topnavbar/topNavbar-shared.css') }}" />
    {% if page_css is defined and page_css %}
      <link rel="stylesheet" href="{{ asset('assets/Topnavbar/' ~ page_css) }}" />
    {% endif %}
    {% block stylesheets %}{% endblock %}
  </head>
  <body class="{{ page_class|default('') }}" data-page="{{ page_key|default('') }}">
    {% set nav_mode = app.user and is_granted('ROLE_EMPLOYEE')
      ? 'employee'
      : (app.user and is_granted('ROLE_CANDIDAT')
        ? 'candidate'
        : null)
    %}
    <div class="app-shell">
      <header class="top-navbar">
        <nav class="top-nav">
          {% if nav_mode == 'employee' %}
            <button class="nav-link" type="button" data-page="communaute" data-href="{{ path('topnav_communaute') }}">Communaute</button>
            <button class="nav-link" type="button" data-page="formations" data-href="{{ path('topnav_formations') }}">Formations</button>
            <button class="nav-link" type="button" data-page="participations" data-href="{{ path('topnav_participations') }}">Mes participations</button>
            <button class="nav-link" type="button" data-page="evenements" data-href="{{ path('topnav_evenements') }}">Evenement</button>
            <button class="nav-link" type="button" data-page="demande-conge" data-href="{{ path('demande_conge') }}">Demande de conges</button>
            <button class="nav-link" type="button" data-page="demande-conge" data-href="{{ path('activity_watch') }}">Activity Watch</button>
          {% elseif nav_mode == 'candidate' %}
            <button class="nav-link" type="button" data-page="offres" data-href="{{ path('topnav_offres') }}">Offre d'emploi</button>
            <button class="nav-link" type="button" data-page="mes-candidatures" data-href="{{ path('topnav_mes_candidatures') }}">Mes Condidatures</button>
          {% endif %}
          <div class="nav-spacer"></div>
          <button id="btnLogoutNav" class="nav-link" type="button" data-href="{{ path('app_logout') }}">Deconnexion</button>
        </nav>
      </header>

      <main class="page-placeholder">
        <section class="interface-shell">
          <h1>{% block content_title %}{% endblock %}</h1>
          {% block content_body %}{% endblock %}
        </section>
      </main>
    </div>

    <script src="{{ asset('assets/Topnavbar/topNavbar.js') }}"></script>
    {% block javascripts %}{% endblock %}
  </body>
</html>
