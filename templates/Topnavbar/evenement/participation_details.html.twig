{% extends 'base_front.html.twig' %}

{% block title %}Résumé de l'inscription - HR One{% endblock %}

{% block body %}
<div style="max-width: 800px; margin: 2rem auto; padding: 0 1rem;">
    {# Fil d'Ariane #}
    <nav style="margin-bottom: 2rem; color: #64748b; font-size: 0.9rem;">
        <a href="{{ path('topnav_evenements') }}" style="color: #64748b; text-decoration: none;">Événements</a> 
        <span style="margin: 0 0.5rem;">/</span> 
        <a href="{{ path('app_front_evenement_show', {id: participation.evenement.IDEvenement}) }}" style="color: #64748b; text-decoration: none;">{{ participation.evenement.Titre }}</a>
        <span style="margin: 0 0.5rem;">/</span> 
        <span style="color: #0f172a; font-weight: 600;">Mon inscription</span>
    </nav>

    {# Header avec succès #}
    <div style="text-align: center; margin-bottom: 3rem;">
        <div style="display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; background: #f0fdf4; border-radius: 50%; color: #16a34a; font-size: 2rem; margin-bottom: 1rem; box-shadow: 0 4px 6px -1px rgba(22,163,74,0.1);">
            ✅
        </div>
        <h1 style="color: #0f172a; margin: 0; font-size: 2rem;">Votre inscription est confirmée !</h1>
        <p style="color: #64748b; margin-top: 0.5rem; font-size: 1.1rem;">Merci <span style="color: #2563eb; font-weight: 600;">{{ participation.nomComplet }}</span>, nous avons hâte de vous voir.</p>
    </div>

    {# Ticket Wrapper #}
    <div style="background: #ffffff; border: 1px solid #e2e8f0; border-radius: 24px; overflow: hidden; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05); display: flex; flex-direction: column;">
        
        {# Partie Haute : Event Header #}
        <div style="background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%); padding: 3rem 2rem; color: white; position: relative;">
            <div style="position: relative; z-index: 2;">
                <span style="display: inline-block; background: rgba(255,255,255,0.2); backdrop-filter: blur(4px); padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1rem;">Ticket de Participation</span>
                <h2 style="font-size: 2.2rem; margin: 0; font-weight: 800; line-height: 1.1;">{{ participation.evenement.Titre }}</h2>
                <div style="margin-top: 1.5rem; display: flex; gap: 2rem; flex-wrap: wrap; font-size: 0.95rem; opacity: 0.9;">
                    <span>📍 {{ participation.evenement.Localisation }}</span>
                    <span>💰 {{ participation.evenement.prix > 0 ? participation.evenement.prix ~ ' DT' : 'Gratuit' }}</span>
                </div>
            </div>
            {# Décoration de fond #}
            <div style="position: absolute; right: -20px; top: -20px; font-size: 10rem; opacity: 0.1; filter: grayscale(1);">📅</div>
        </div>

        {# Partie Basse : Info #}
        <div style="padding: 2.5rem; position: relative;">
            {# Petite encoche façon ticket #}
            <div style="position: absolute; top: 0; left: 50%; transform: translate(-50%, -50%); display: flex; width: 100%; justify-content: space-between; padding: 0 40px;">
                <div style="width: 24px; height: 24px; background: #f8fafc; border-radius: 50%; border: 1px solid #e2e8f0;"></div>
                <div style="width: 24px; height: 24px; background: #f8fafc; border-radius: 50%; border: 1px solid #e2e8f0;"></div>
            </div>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2.5rem;">
                {# Infos Participant #}
                <div>
                    <h4 style="color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.8rem;">Participant</h4>
                    <p style="font-weight: 700; font-size: 1.1rem; color: #0f172a; margin: 0;">{{ participation.nomComplet }}</p>
                    <p style="color: #64748b; font-size: 0.9rem; margin-top: 0.2rem;">{{ participation.email }}</p>
                </div>

                {# Mode Paiement #}
                <div>
                    <h4 style="color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.8rem;">Mode de paiement</h4>
                    <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: #f1f5f9; padding: 6px 12px; border-radius: 8px;">
                        <span style="font-size: 1.2rem;">💳</span>
                        <span style="font-weight: 600; color: #334155;">{{ participation.modePaiement|default('Non spécifié') }}</span>
                    </div>
                </div>

                {# ID Ticket #}
                <div style="text-align: right;">
                    <h4 style="color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.8rem;">Référence</h4>
                    <p style="font-family: monospace; font-weight: 700; color: #2563eb; font-size: 1.1rem;">#HR1-{{ participation.idParticipant }}</p>
                </div>
            </div>

            <hr style="border: 0; border-top: 1px dashed #e2e8f0; margin: 2.5rem 0;">

            {# Activité et QR Code #}
            <div style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start;">
                <div>
                    <h4 style="color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.5rem;">🎯 Activité sélectionnée</h4>
                    {% if participation.activite %}
                        <div style="background: #f8fafc; border: 1px solid #f1f5f9; padding: 1rem; border-radius: 12px; display: flex; align-items: center; gap: 0.8rem;">
                            <div style="width: 8px; height: 8px; background: #2563eb; border-radius: 50%;"></div>
                            <span style="font-weight: 600; color: #334155;">{{ participation.activite.Titre }}</span>
                        </div>
                        {% if participation.activite.Description %}
                        <p style="color: #64748b; font-size: 0.9rem; margin-top: 0.8rem; line-height: 1.5;">{{ participation.activite.Description }}</p>
                        {% endif %}
                    {% else %}
                        <p style="color: #94a3b8; font-style: italic;">Aucune activité spécifique sélectionnée.</p>
                    {% endif %}
                </div>

                {# QR Code #}
                <div style="text-align: center;">
                    <h4 style="color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1rem;">QR Code du Ticket</h4>
                    <img src="{{ path('app_front_participation_qr_code', {
                        idParticipant: participation.idParticipant,
                        idEvenement: participation.evenement.IDEvenement,
                        idActivite: participation.activite.IDActivite
                    }) }}" 
                         alt="QR code ticket" 
                         style="width: 180px; height: 180px; border: 1px solid #e2e8f0; border-radius: 12px; background: #ffffff; padding: 10px;">
                    <p style="font-size: 0.75rem; color: #64748b; margin-top: 0.5rem;">Présentez ce code à l'entrée</p>
                </div>
            </div>
        </div>

        {# Footer Ticket #}
        <div style="background: #f8fafc; border-top: 1px solid #e2e8f0; padding: 1.5rem 2.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
            <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                <a href="{{ path('app_front_participation_pdf', {
                    idParticipant: participation.idParticipant,
                    idEvenement: participation.evenement.IDEvenement,
                    idActivite: participation.activite.IDActivite
                }) }}" style="background: linear-gradient(135deg, #2563eb, #1e40af); padding: 8px 16px; border-radius: 8px; font-weight: 600; color: white; text-decoration: none; display: flex; align-items: center; gap: 0.5rem; transition: all 0.2s; box-shadow: 0 4px 6px -1px rgba(37,99,235,0.2);">
                    📥 Télécharger mon Ticket (PDF)
                </a>
                <button onclick="window.print()" style="background: white; border: 1px solid #cbd5e1; padding: 8px 16px; border-radius: 8px; font-weight: 600; color: #334155; cursor: pointer; transition: all 0.2s;">
                    🖨️ Imprimer
                </button>
            </div>
        </div>
    </div>

    <div style="margin-top: 1.5rem; text-align: center;">
        <a href="{{ path('topnav_evenements') }}" style="color: #64748b; text-decoration: none; font-size: 0.9rem;">
            Retour aux événements
        </a>
    </div>
</div>

<style>
    @media print {
        header, nav, footer, button, .app-flashes { display: none !important; }
        body { background: white !important; }
        div[style*="max-width: 800px"] { margin: 0 !important; width: 100% !important; max-width: none !important; }
        div[style*="border: 1px solid"] { border: 1px solid #000 !important; box-shadow: none !important; }
    }
</style>
{% endblock %}
