<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body { 
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; 
            background-color: #f8fafc; 
            margin: 0; 
            padding: 0; 
            -webkit-font-smoothing: antialiased;
        }
        .wrapper {
            background-color: #f8fafc;
            padding: 40px 20px;
        }
        .container { 
            max-width: 600px; 
            margin: 0 auto; 
            background-color: #ffffff; 
            border-radius: 16px; 
            overflow: hidden; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.05), 0 5px 10px rgba(0,0,0,0.05); 
        }
        .header { 
            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%); 
            padding: 40px 30px; 
            text-align: center; 
            color: white; 
        }
        .header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.5px;
            text-transform: uppercase;
        }
        .header p {
            margin: 8px 0 0;
            opacity: 0.9;
            font-size: 16px;
        }
        .content { 
            padding: 40px 30px; 
            line-height: 1.7; 
            color: #334155;
            font-size: 16px;
        }
        .footer { 
            background-color: #f1f5f9; 
            padding: 30px; 
            text-align: center; 
            font-size: 13px; 
            color: #64748b; 
            border-top: 1px solid #e2e8f0;
        }
        .btn { 
            display: inline-block; 
            padding: 14px 30px; 
            background-color: #2563eb; 
            color: #ffffff !important; 
            text-decoration: none; 
            border-radius: 8px; 
            font-weight: 700; 
            margin-top: 25px;
            box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2);
            transition: transform 0.2s ease;
        }
        .highlight { 
            color: #2563eb; 
            font-weight: 700; 
        }
        .card {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 20px;
            margin: 20px 0;
        }
        ul {
            padding-left: 20px;
            margin: 10px 0;
        }
        li {
            margin-bottom: 8px;
        }
        .social-links {
            margin-top: 15px;
        }
        .social-links a {
            color: #94a3b8;
            text-decoration: none;
            margin: 0 10px;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <h1>HROne</h1>
                <p>Votre Excellence RH au Quotidien</p>
            </div>
            <div class="content">
                {% block content %}{% endblock %}
            </div>
            <div class="footer">
                <strong>HROne Platform</strong><br>
                Solutions Innovantes pour la Gestion des Talents
                <div class="social-links">
                    <a href="#">LinkedIn</a> &bull; <a href="#">Website</a> &bull; <a href="#">Support</a>
                </div>
                <p style="margin-top: 20px; font-size: 11px; opacity: 0.7;">
                    &copy; 2026 HROne. Tous droits réservés.<br>
                    Cet email a été envoyé automatiquement, merci de ne pas y répondre.
                </p>
            </div>
        </div>
    </div>
</body>
</html>
