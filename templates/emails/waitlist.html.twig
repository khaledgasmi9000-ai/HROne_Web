{% extends 'emails/layout.html.twig' %}

{% block content %}
    <h2 style="color: #1e293b; margin-top: 0;">Bonjour {{ waitlist.nomComplet }},</h2>
    
    <p>Nous avons bien reçu votre demande d'inscription pour l'événement :</p>
    
    <div class="card" style="border-left: 4px solid #f59e0b;">
        <h3 style="margin: 0; color: #d97706;">⏳ Liste d'Attente</h3>
        <p style="margin: 5px 0 0; color: #1e293b; font-weight: 600;">{{ waitlist.evenement.titre }}</p>
        <p style="margin: 5px 0 0; color: #64748b; font-size: 14px;">L'événement est actuellement complet.</p>
    </div>
    
    <p>Vous avez été placé(e) en <strong>priorité</strong> sur notre liste d'attente. Nous gérons celle-ci par ordre de demande.</p>
    
    <div style="background-color: #fef3c7; border-radius: 8px; padding: 20px; color: #92400e; font-size: 15px;">
        <strong>Note :</strong> Si un participant se désiste, votre place sera <strong>automatiquement confirmée</strong> et vous recevrez un nouvel email de notre part.
    </div>

    <p style="margin-top: 30px;">Merci pour votre enthousiasme et votre patience.</p>
    
    <div style="text-align: center;">
        <a href="{{ url('app_front_evenement_show', {id: waitlist.evenement.IDEvenement}) }}" class="btn">Voir les détails de l'événement</a>
    </div>
    
    <p style="margin-top: 40px; border-top: 1px solid #f1f5f9; padding-top: 20px;">
        Cordialement,<br>
        <span style="font-weight: 700; color: #1e3a8a;">L'équipe RH HROne</span>
    </p>
{% endblock %}
