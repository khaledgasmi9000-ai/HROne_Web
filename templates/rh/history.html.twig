{% extends 'base.html.twig' %}

{% block title %}Historique des actions{% endblock %}

{% block body %}
    <section class="interface-shell">
        <div class="section-header">
            <div>
                <h1>Historique des actions</h1>
                <p>Journal des actions des utilisateurs RH/Admin avec type d action, commentaire et horodatage.</p>
            </div>
        </div>

        <form method="get" class="filters-bar">
            <input type="text" name="q" value="{{ search }}" placeholder="Rechercher par utilisateur, email, action ou commentaire">
            <button class="btn btn-primary" type="submit">Rechercher</button>
            <a class="btn btn-secondary" href="{{ path('app_rh_history') }}">Reinitialiser</a>
        </form>

        <div class="table-shell">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Utilisateur</th>
                        <th>Email</th>
                        <th>Action</th>
                        <th>Commentaire</th>
                        <th>Date</th>
                        <th>Ordre</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in rows %}
                        <tr>
                            <td>{{ row.Nom_Utilisateur ?: '-' }}</td>
                            <td>{{ row.Email ?: '-' }}</td>
                            <td>{{ row.Description_Action ?: '-' }}</td>
                            <td>{{ row.Commentaire ?: '-' }}</td>
                            <td>{{ '%04d-%02d-%02d %02d:%02d:%02d'|format(row.AAAA ?: 0, row.MM ?: 0, row.JJ ?: 0, row.HH ?: 0, row.MN ?: 0, row.SS ?: 0) }}</td>
                            <td>{{ row.Num_Ordre ?: '-' }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6">Aucune action trouvee.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
