{% extends 'base.html.twig' %}

{% block title %}Detail utilisateur{% endblock %}

{% block body %}
    <section class="interface-shell">
        <div class="section-header">
            <div>
                <h1>Detail utilisateur</h1>
                <p>Consultation complete du compte avec action RH/Admin sur le statut.</p>
            </div>
            <a class="btn btn-secondary" href="{{ path('app_rh_user_index') }}">Retour a la liste</a>
        </div>

        <section class="user-detail-hero">
            <div class="user-detail-identity">
                <div class="user-avatar-lg">{{ userItem.nomUtilisateur ? userItem.nomUtilisateur|slice(0, 1)|upper : 'U' }}</div>
                <div>
                    <span class="section-kicker">Compte utilisateur</span>
                    <h2>{{ userItem.nomUtilisateur }}</h2>
                    <p>{{ userItem.email ?: 'Email non renseigne' }}</p>
                </div>
            </div>
            <div class="user-detail-side">
                <span class="status-chip {{ userItem.active ? 'status-active' : 'status-inactive' }}">
                    {{ userItem.active ? 'Compte actif' : 'Compte inactif' }}
                </span>
                <div class="completion-cell completion-cell-large">
                    <div class="completion-bar">
                        <span style="width: {{ userItem.profileCompletionScore }}%"></span>
                    </div>
                    <small>Completude du profil : {{ userItem.profileCompletionScore }}%</small>
                </div>
            </div>
        </section>

        <div class="details-grid details-grid-user">
            <div class="detail-card"><span>ID</span><strong>{{ userItem.IDUTILISATEUR }}</strong></div>
            <div class="detail-card"><span>Nom utilisateur</span><strong>{{ userItem.nomUtilisateur }}</strong></div>
            <div class="detail-card"><span>Email</span><strong>{{ userItem.email ?: 'Non renseigne' }}</strong></div>
            <div class="detail-card"><span>Profil</span><strong>{{ userItem.profil ? userItem.profil.nomProfil : 'Non renseigne' }}</strong></div>
            <div class="detail-card"><span>Telephone</span><strong>{{ userItem.numTel ?: 'Non renseigne' }}</strong></div>
            <div class="detail-card"><span>CIN</span><strong>{{ userItem.CIN ?: 'Non renseigne' }}</strong></div>
            <div class="detail-card"><span>Adresse</span><strong>{{ userItem.adresse ?: 'Non renseignee' }}</strong></div>
            <div class="detail-card"><span>Statut</span><strong>{{ userItem.active ? 'Actif' : 'Inactif' }}</strong></div>
            <div class="detail-card"><span>Completude du profil</span><strong>{{ userItem.profileCompletionScore }}%</strong></div>
            <div class="detail-card"><span>Niveau du profil</span><strong>{{ userItem.profileComplete ? 'Complet' : 'A completer' }}</strong></div>
        </div>

        <section class="ai-panel">
            <div class="section-header ai-panel-header">
                <div>
                    <h2>Assistant IA du profil</h2>
                    <p>Generation d un resume rapide du compte a partir des informations utilisateur via une API IA gratuite.</p>
                </div>
                <button
                    type="button"
                    class="btn btn-primary"
                    id="ai-generate-user-summary"
                    data-user-prompt="Resume ce profil utilisateur RH en 4 lignes maximum et donne 2 recommandations courtes pour completer ou ameliorer le compte. Nom: {{ userItem.nomUtilisateur|e('html_attr') }}. Email: {{ (userItem.email ?: 'Non renseigne')|e('html_attr') }}. Telephone: {{ (userItem.numTel ?: 'Non renseigne')|e('html_attr') }}. CIN: {{ (userItem.CIN ?: 'Non renseigne')|e('html_attr') }}. Adresse: {{ (userItem.adresse ?: 'Non renseignee')|e('html_attr') }}. Date de naissance: {{ (userItem.dateNaissance ? userItem.dateNaissance|date('Y-m-d') : 'Non renseignee')|e('html_attr') }}. Genre: {{ (userItem.gender ?: 'Non renseigne')|e('html_attr') }}. Profil: {{ (userItem.profil ? userItem.profil.nomProfil : 'Non renseigne')|e('html_attr') }}. Completude: {{ userItem.profileCompletionScore }} pourcent."
                    data-user-name="{{ userItem.nomUtilisateur|default('Utilisateur')|e('html_attr') }}"
                    data-user-email="{{ (userItem.email ?: 'Non renseigne')|e('html_attr') }}"
                    data-user-phone="{{ (userItem.numTel ?: 'Non renseigne')|e('html_attr') }}"
                    data-user-address="{{ (userItem.adresse ?: 'Non renseignee')|e('html_attr') }}"
                    data-user-role="{{ (userItem.profil ? userItem.profil.nomProfil : 'Non renseigne')|e('html_attr') }}"
                    data-user-completion="{{ userItem.profileCompletionScore }}">
                    Generer un resume IA
                </button>
            </div>

            <div class="ai-output" id="ai-user-summary-output">
                Cliquez sur le bouton pour generer un resume IA du profil.
            </div>
        </section>

        <form method="post" action="{{ path('app_rh_user_toggle', { id: userItem.IDUTILISATEUR }) }}" class="inline-form">
            <input type="hidden" name="_token" value="{{ csrf_token('toggle_user_' ~ userItem.IDUTILISATEUR) }}">
            <button class="btn {{ userItem.active ? 'btn-danger' : 'btn-primary' }}" type="submit">
                {{ userItem.active ? 'Desactiver le compte' : 'Activer le compte' }}
            </button>
        </form>
    </section>

    <script>
      (() => {
        const button = document.getElementById('ai-generate-user-summary');
        const output = document.getElementById('ai-user-summary-output');

        if (!button || !output) {
          return;
        }

        const buildLocalSummary = () => {
          const name = button.dataset.userName || 'Utilisateur';
          const email = button.dataset.userEmail || 'Non renseigne';
          const phone = button.dataset.userPhone || 'Non renseigne';
          const address = button.dataset.userAddress || 'Non renseignee';
          const role = button.dataset.userRole || 'Non renseigne';
          const completion = Number(button.dataset.userCompletion || 0);
          const missing = [];

          if (phone === 'Non renseigne') {
            missing.push('ajouter un numero de telephone');
          }

          if (address === 'Non renseignee') {
            missing.push('completer l adresse');
          }

          if (email === 'Non renseigne') {
            missing.push('renseigner un email valide');
          }

          const completionLabel = completion >= 80
            ? 'profil bien renseigne'
            : completion >= 50
              ? 'profil partiellement complete'
              : 'profil encore incomplet';

          const recommendations = missing.length > 0
            ? missing.slice(0, 2)
            : ['verifier la coherence des informations saisies', 'maintenir le compte a jour'];

          return [
            `${name} est un utilisateur de type ${role} avec un ${completionLabel} (${completion}% de completude).`,
            `Le compte est joignable via ${email}${phone !== 'Non renseigne' ? ` et le numero ${phone}` : ''}.`,
            address !== 'Non renseignee'
              ? `L adresse renseignee est ${address}.`
              : 'Certaines informations de contact restent a completer.',
            `Recommandations : ${recommendations[0]} ; ${recommendations[1]}.`,
          ].join('\n');
        };

        const isNoticeResponse = (text) => {
          const normalized = text.toLowerCase();

          return normalized.includes('important notice')
            || normalized.includes('pollinations legacy text api')
            || normalized.includes('authenticated users')
            || normalized.includes('enter.pollinations.ai');
        };

        button.addEventListener('click', async () => {
          const prompt = button.dataset.userPrompt;

          button.disabled = true;
          output.textContent = 'Generation en cours...';

          try {
            const response = await fetch(`https://text.pollinations.ai/${encodeURIComponent(prompt)}`);

            if (!response.ok) {
              throw new Error('API IA indisponible');
            }

            const text = (await response.text()).trim();

            if (!text || isNoticeResponse(text)) {
              output.textContent = buildLocalSummary();
              return;
            }

            output.textContent = text;
          } catch (error) {
            output.textContent = buildLocalSummary();
          } finally {
            button.disabled = false;
          }
        });
      })();
    </script>
{% endblock %}
