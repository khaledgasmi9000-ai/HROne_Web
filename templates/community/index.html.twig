{% extends 'base.html.twig' %}

{% block body %}
<style>
  :root {
    --bg: #f3f5f9;
    --card: #ffffff;
    --text: #0f172a;
    --muted: #64748b;
    --border: #e2e8f0;
    --primary: #2563eb;
    --green: #16a34a;
    --red: #dc2626;
  }
  body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', sans-serif; margin: 0; }
  .page { max-width: 1240px; margin: 0 auto; padding: 16px; }
  .header { background: #0f172a; color: #e2e8f0; border-radius: 12px; padding: 12px 16px; margin-bottom: 14px; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .topbar { background: #0f172a; color: #e2e8f0; border-radius: 12px; padding: 12px 16px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .navbar { background: #ffffff; border: 1px solid var(--border); border-radius: 999px; padding: 8px; margin-bottom: 14px; display: flex; gap: 8px; flex-wrap: wrap; }
  .navbar a { background: transparent; border: none; border-radius: 999px; padding: 8px 12px; color: #0f172a; text-decoration: none; }
  .navbar a.active { background: var(--primary); color: #fff; }
  .header small { color: #94a3b8; display: block; }
  .layout { display: grid; grid-template-columns: 320px 1fr; gap: 14px; align-items: start; }
  .card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 12px; margin-bottom: 12px; box-shadow: 0 6px 20px rgba(15,23,42,.06); }
  .muted { color: var(--muted); }
  .stack { display: flex; flex-direction: column; gap: 8px; }
  .inline { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  input, textarea, select { width: 100%; border: 1px solid var(--border); border-radius: 10px; padding: 10px 12px; box-sizing: border-box; }
  textarea { min-height: 90px; resize: vertical; }
  .btn { border: none; border-radius: 10px; padding: 10px 12px; text-decoration: none; cursor: pointer; font-weight: 600; }
  .btn.primary { background: var(--primary); color: #fff; }
  .btn.gray { background: #e2e8f0; color: #0f172a; }
  .btn.green { background: var(--green); color: #fff; }
  .btn.red { background: var(--red); color: #fff; }
  .actions { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
  .post { margin-bottom: 14px; }
  .post h3 { margin: 0; font-size: 18px; }
  .meta { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .badge { display: inline-block; padding: 3px 8px; border-radius: 999px; font-size: 12px; background: #e2e8f0; }
  .badge.pin { background: #f59e0b; color: #fff; }
  .badge.hidden { background: #94a3b8; color: #fff; }
  .metrics { display: flex; gap: 6px; flex-wrap: wrap; margin: 8px 0; }
  .metric { background: #f8fafc; border: 1px solid var(--border); border-radius: 999px; padding: 6px 10px; font-size: 13px; }
  .comment { border-top: 1px solid var(--border); padding-top: 8px; margin-top: 8px; }
  .comment.reply { margin-left: 18px; border-left: 3px solid var(--border); padding-left: 10px; }
  .flash { padding: 10px 12px; border-radius: 10px; margin-bottom: 10px; }
  .flash.success { background: #dcfce7; color: #166534; border: 1px solid #86efac; }
  .flash.error { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
  .flash.notice { background: #e0f2fe; color: #0c4a6e; border: 1px solid #7dd3fc; }
  .top-nav { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
  .top-nav a { background: #fff; border: 1px solid var(--border); border-radius: 999px; padding: 8px 12px; color: #0f172a; text-decoration: none; }
  .top-nav a.active { background: var(--primary); color: #fff; border-color: var(--primary); }
  .footer { margin-top: 20px; background: #0f172a; color: #e2e8f0; border-radius: 12px; padding: 14px 16px; display: flex; justify-content: space-between; gap: 10px; flex-wrap: wrap; }
  .footer small { color: #94a3b8; }
  @media (max-width: 980px) {
    .layout { grid-template-columns: 1fr; }
  }
</style>

<div class="page">
  <header class="topbar">
    <div>
      <strong>HR One</strong>
      <small>Communaute & collaborateurs</small>
    </div>
    <div class="muted">Espace collaboratif</div>
  </header>

  <nav class="navbar">
    <a href="#">Offres d emploi</a>
    <a href="#">Formations</a>
    <a href="#">Evenements</a>
    <a href="#">Mes participations</a>
    <a href="#">Demande de conge</a>
    <a class="active" href="{{ path('community_index') }}">Communaute</a>
  </nav>

  <header class="header">
    <div>
      <strong>Tableau Communaute</strong>
      <small>Navbar + feed + modules</small>
    </div>
    <div class="muted">HR One</div>
  </header>

  {% for type, messages in app.flashes %}
    {% for message in messages %}
      <div class="flash {{ type == 'error' ? 'error' : (type == 'success' ? 'success' : 'notice') }}">{{ message }}</div>
    {% endfor %}
  {% endfor %}

  <div class="card">
    <form method="get" action="{{ path('community_index') }}" class="inline">
      <div style="flex:2; min-width:220px;">
        <input name="q" value="{{ currentSearch }}" placeholder="Titre contient...">
      </div>
      <div style="flex:1; min-width:180px;">
        <select name="tag">
          <option value="">Tous les tags</option>
          {% for t in tags %}
            <option value="{{ t }}" {% if t == currentTag %}selected{% endif %}>{{ t }}</option>
          {% endfor %}
        </select>
      </div>
      <div style="width:150px;">
        <select name="comment_sort">
          <option value="asc" {% if commentSort == 'asc' %}selected{% endif %}>Commentaires asc</option>
          <option value="recent" {% if commentSort == 'recent' %}selected{% endif %}>Commentaires recents</option>
          <option value="flagged" {% if commentSort == 'flagged' %}selected{% endif %}>Commentaires signales</option>
        </select>
      </div>
      <div style="width:120px;">
        <select name="per_page">
          {% for n in [5,10,15,20] %}
            <option value="{{ n }}" {% if perPage == n %}selected{% endif %}>{{ n }}/page</option>
          {% endfor %}
        </select>
      </div>
      <button class="btn primary" type="submit">Appliquer</button>
      <span class="btn green">Like {{ totalLikes }}</span>
      <span class="btn red">Dislike {{ totalDislikes }}</span>
    </form>
  </div>

  <div class="layout">
    <aside>
      <div class="card">
        <h4 style="margin:0 0 8px 0;">Meteo du jour (Tunis)</h4>
        {% if weather.error %}
          <div class="muted">{{ weather.error }}</div>
        {% else %}
          <div style="font-size:24px; font-weight:700;">{{ weather.temperature }} C</div>
          <div class="muted">Vent {{ weather.windspeed }} km/h · code {{ weather.weathercode }}</div>
          <div class="muted" style="margin-top:6px;">Mise a jour automatique cote serveur</div>
        {% endif %}
      </div>

      <div class="card">
        <h4 style="margin:0 0 8px 0;">Chatbot IA</h4>
        <form method="get" action="{{ path('community_index') }}" class="stack">
          <input type="hidden" name="q" value="{{ currentSearch }}">
          <input type="hidden" name="tag" value="{{ currentTag }}">
          <input type="hidden" name="per_page" value="{{ perPage }}">
          <input type="hidden" name="comment_sort" value="{{ commentSort }}">
          <textarea name="bot_q" placeholder="Pose ta question...">{{ botQuestion }}</textarea>
          <button class="btn primary" type="submit">Envoyer</button>
        </form>
        <div class="card" style="margin:10px 0 0 0; background:#f8fafc;">
          {% if botAnswer %}
            {{ botAnswer }}
          {% else %}
            <span class="muted">Pose une question pour obtenir une reponse.</span>
          {% endif %}
        </div>
      </div>

      <div class="card">
        <h4 style="margin:0 0 8px 0;">Chat interne local</h4>
        <div style="max-height:240px; overflow:auto; border:1px solid var(--border); border-radius:10px; padding:8px; background:#f8fafc;">
          {% for m in chatMessages %}
            <div style="margin-bottom:6px;">
              <strong>{{ m.user|default('User') }}</strong>
              <span class="muted">· {{ m.at|default('') }}</span>
              <div>{{ m.text|default('') }}</div>
            </div>
          {% else %}
            <div class="muted">Aucun message.</div>
          {% endfor %}
        </div>
        <form method="post" action="{{ path('community_chat_send') }}" class="stack" style="margin-top:8px;">
          <input name="message" placeholder="Ecris un message...">
          <button class="btn primary" type="submit">Envoyer</button>
        </form>
        <form method="post" action="{{ path('community_chat_clear') }}" style="margin-top:8px;">
          <button class="btn gray" type="submit">Vider le chat</button>
        </form>
      </div>
    </aside>

    <main>
      <div class="card">
        <h3 style="margin:0 0 8px 0;">Creer une publication</h3>
        <form method="post" action="{{ path('community_post_create') }}" enctype="multipart/form-data" class="stack">
          <input name="title" placeholder="Titre du post">
          <textarea name="description" placeholder="Ecris ton message..."></textarea>
          <input name="image_url" placeholder="https://... (optionnel)">
          <label class="muted">Image fichier (optionnel)</label>
          <input name="image_file" type="file" accept="image/*">
          <input name="tag" placeholder="#tag">
          <input type="hidden" name="user_id" value="1">
          <input type="hidden" name="is_active" value="1">
          <button class="btn primary" type="submit">Publier</button>
        </form>
      </div>

      {% for post in posts %}
        <article class="card post">
          <div class="inline" style="justify-content:space-between; align-items:flex-start;">
            <div>
              <h3>{{ post.title }}</h3>
              <div class="meta">#{{ post.userId }} · {{ post.createdAt|date('d/m/Y H:i') }}</div>
            </div>
            <div class="inline">
              {% if post.tag and post.tag|lower starts with 'pin' %}
                <span class="badge pin">Epingle</span>
              {% endif %}
              {% if post.tag %}
                <span class="badge">{{ post.tag }}</span>
              {% endif %}
            </div>
          </div>

          {% set rawImage = post.imageUrl %}
          {% set uploadedImage = (rawImage and (rawImage starts with 'http://' or rawImage starts with 'https://')) ? null : (rawImage ? '/uploads/post_images/' ~ rawImage : null) %}
          {% set displayImage = uploadedImage ?: rawImage %}
          {% if displayImage %}
            {% if uploadedImage %}
              <img src="{{ uploadedImage|imagine_filter('thumb_300') }}" alt="" style="width:100%;border-radius:10px;max-height:360px;object-fit:cover;margin-top:8px;">
            {% else %}
              <img src="{{ displayImage }}" alt="" style="width:100%;border-radius:10px;max-height:360px;object-fit:cover;margin-top:8px;">
            {% endif %}
          {% endif %}

          {% if post.description %}
            <p>{{ post.description }}</p>
          {% endif %}

          <div class="metrics">
            <span class="metric">Vues {{ viewsCounts[post.id]|default(0) }}</span>
            <span class="metric">Partages {{ shareCounts[post.id]|default(0) }}</span>
            <span class="metric">Sauvegardes {{ saveCounts[post.id]|default(0) }}</span>
            <span class="metric">Engagement {{ engagementRates[post.id]|default(0) }}%</span>
          </div>

          <div class="actions">
            <form method="post" action="{{ path('community_post_vote', {id: post.id, type: 'up'}) }}">
              <button class="btn green" type="submit">Like {{ postVoteCounts[post.id].up|default(0) }}</button>
            </form>
            <form method="post" action="{{ path('community_post_vote', {id: post.id, type: 'down'}) }}">
              <button class="btn red" type="submit">Dislike {{ postVoteCounts[post.id].down|default(0) }}</button>
            </form>
            <form method="post" action="{{ path('community_post_fav', {id: post.id}) }}">
              <button class="btn gray" type="submit">{{ post.id in favorites ? 'Favori' : 'Ajouter favori' }}</button>
            </form>
            <form method="post" action="{{ path('community_post_delete', {id: post.id}) }}">
              <button class="btn red" type="submit">Supprimer</button>
            </form>
          </div>

          <details style="margin-top:10px;">
            <summary>Modifier ce post</summary>
            <form method="post" action="{{ path('community_post_update', {id: post.id}) }}" enctype="multipart/form-data" class="stack" style="margin-top:8px;">
              <input name="title" value="{{ post.title }}">
              <textarea name="description">{{ post.description }}</textarea>
              <input name="image_url" value="{{ (post.imageUrl starts with 'http://' or post.imageUrl starts with 'https://') ? post.imageUrl : '' }}" placeholder="URL image externe (optionnel)">
              <input name="image_file" type="file" accept="image/*">
              <input name="tag" value="{{ post.tag }}">
              <button class="btn primary" type="submit">Enregistrer</button>
            </form>
          </details>

          <div class="comment">
            <h4 style="margin:0 0 8px 0;">Commentaires ({{ commentCounts[post.id]|default(0) }})</h4>
            {% for c in commentsByPost[post.id]|default([]) %}
              <div class="comment {% if c.parentCommentId %}reply{% endif %}">
                <p style="margin:0;">
                  <strong>#{{ c.userId }}</strong>
                  {% if c.id in pinned %}<span class="badge pin">Epingle</span>{% endif %}
                  {% if not c.isActive %}<span class="badge hidden">Masque</span>{% endif %}
                  {{ c.content }}
                </p>
                <div class="actions" style="margin-top:6px;">
                  <form method="post" action="{{ path('community_comment_vote', {id: c.id, type: 'up'}) }}">
                    <button class="btn green" type="submit">Like {{ voteCounts[c.id].up|default(0) }}</button>
                  </form>
                  <form method="post" action="{{ path('community_comment_vote', {id: c.id, type: 'down'}) }}">
                    <button class="btn red" type="submit">Dislike {{ voteCounts[c.id].down|default(0) }}</button>
                  </form>
                  <form method="post" action="{{ path('community_comment_pin', {id: c.id}) }}">
                    <button class="btn gray" type="submit">{{ c.id in pinned ? 'Desepingler' : 'Epingler' }}</button>
                  </form>
                  <form method="post" action="{{ path('community_comment_toggle', {id: c.id}) }}">
                    <button class="btn gray" type="submit">{{ c.isActive ? 'Masquer' : 'Afficher' }}</button>
                  </form>
                  <form method="post" action="{{ path('community_comment_delete', {id: c.id}) }}">
                    <button class="btn red" type="submit">Supprimer</button>
                  </form>
                </div>

                <details style="margin-top:6px;">
                  <summary>Modifier commentaire</summary>
                  <form method="post" action="{{ path('community_comment_update', {id: c.id}) }}" class="stack" style="margin-top:6px;">
                    <input name="content" value="{{ c.content }}">
                    <button class="btn primary" type="submit">Enregistrer</button>
                  </form>
                </details>

                <form method="post" action="{{ path('community_comment_create') }}" class="stack" style="margin-top:8px;">
                  <input type="hidden" name="post_id" value="{{ post.id }}">
                  <input type="hidden" name="parent_comment_id" value="{{ c.id }}">
                  <input type="hidden" name="user_id" value="1">
                  <input name="content" placeholder="Repondre...">
                  <button class="btn primary" type="submit">Repondre</button>
                </form>
              </div>
            {% else %}
              <p class="muted">Aucun commentaire pour le moment.</p>
            {% endfor %}

            <form method="post" action="{{ path('community_comment_create') }}" class="stack" style="margin-top:10px;">
              <input type="hidden" name="post_id" value="{{ post.id }}">
              <input type="hidden" name="user_id" value="1">
              <input name="content" placeholder="Ajouter un commentaire...">
              <button class="btn primary" type="submit">Commenter</button>
            </form>
          </div>
        </article>
      {% else %}
        <div class="card muted">Aucun post disponible.</div>
      {% endfor %}

      {{ knp_pagination_render(pagination) }}
    </main>
  </div>

  <footer class="footer">
    <div>
      <strong>Footer HR One</strong>
      <small>Contact: support@hrone.tn</small>
    </div>
    <div>
      <small>Modules: Communaute, RH, Conges, Evenements</small><br>
      <small>&copy; {{ 'now'|date('Y') }} HR One</small>
    </div>
  </footer>
</div>
{% endblock %}
