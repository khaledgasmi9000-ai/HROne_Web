<!DOCTYPE html>
<html lang="{{ app.request.locale }}" dir="{{ app.request.locale == 'ar' ? 'rtl' : 'ltr' }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ 'community.meta_title.feed'|trans }}</title>
  <link rel="stylesheet" href="/topNavbar/topNavbar-shared.css" />
  <link rel="stylesheet" href="/topNavbar/communaute.css" />
  <link rel="stylesheet" href="/topNavbar/communaute-app.css" />
  <link rel="stylesheet" href="/topNavbar/community-dashboard.css" />
  <link rel="stylesheet" href="/topNavbar/community-enhancements.css" />
</head>
<body class="page-communaute" data-page="communaute">
  <script>
  window.__COMMUNITY_UI__ = {{ {
    locale: app.request.locale,
    strings: {
      confirmDeletePost: 'js.confirm_delete_post'|trans,
      confirmDeleteComment: 'js.confirm_delete_comment'|trans,
      validationTitle: 'js.validation.title_required'|trans,
      validationUrl: 'js.validation.url_invalid'|trans,
      validationTag: 'js.validation.tag_long'|trans,
      validationTagChars: 'js.validation.tag_chars'|trans,
      validationComment: 'js.validation.comment_long'|trans,
      commentRequired: 'js.validation.comment_required'|trans,
      validationSearch: 'js.validation.search_long'|trans,
    },
  }|json_encode(constant('JSON_UNESCAPED_UNICODE'))|raw }};
  </script>
  <div class="app-shell">
    <header class="top-navbar">
      <nav class="top-nav">
        <button id="btnOffres" class="nav-link" type="button" data-page="offres" data-href="/topNavbar/topNavbar.html">Offres d'emploi</button>
        <button id="btnTraining" class="nav-link" type="button" data-page="formations" data-href="/topNavbar/formations.html">Formations</button>
        <button id="btnEvents" class="nav-link" type="button" data-page="evenements" data-href="/topNavbar/evenements.html">Événements</button>
        <button id="btnParticipation" class="nav-link" type="button" data-page="participations" data-href="/topNavbar/participations.html">Mes participations</button>
        <button id="btnDemandeConge" class="nav-link" type="button" data-page="demande-conge" data-href="/topNavbar/demande-conge.html">Demande de congé</button>
        <button id="btnCommunaute" class="nav-link is-active" type="button" data-page="communaute" data-href="{{ path('app_communaute') }}">Communauté</button>
      </nav>
    </header>

    <main class="page-placeholder">
      <section class="interface-shell community-app">
        {% include 'community/_lang_switch.html.twig' with { route_name: 'app_communaute' } only %}

        <nav class="community-subnav card" aria-label="{{ 'community.nav.feed'|trans }}">
          <span class="subnav-link is-current" aria-current="page">{{ 'community.nav.feed'|trans }}</span>
          <span class="subnav-sep" aria-hidden="true">|</span>
          <a class="subnav-link" href="{{ path('app_communaute_dashboard') }}">{{ 'community.nav.dashboard'|trans }}</a>
        </nav>

        <header class="community-hero">
          <h1>{{ 'community.feed.title'|trans }}</h1>
          <p class="lead">{{ 'community.feed.lead'|trans|raw }}</p>
        </header>

        <div class="community-layout">
          <div class="community-main">
            <div class="card session-card community-toolbar-grid">
              <label class="field-inline">
                <span>{{ 'community.session.user_id'|trans }}</span>
                <input type="number" id="currentUserId" min="1" step="1" required inputmode="numeric" title="{{ 'community.validation.user_id_hint'|trans }}" value="{{ initial_user_id ?? 1 }}" />
              </label>
              <button type="button" class="btn-secondary" id="btnSessionApply">{{ 'community.session.connect'|trans }}</button>
              <button type="button" class="btn-ghost" id="btnRefreshFeed">{{ 'community.session.refresh_feed'|trans }}</button>
              <span id="sessionStatus" class="session-status" aria-live="polite"></span>
            </div>

            {% include 'community/_feature_toolbar.html.twig' %}

            <div class="card filters-bar filters-bar-extended">
              <label class="field-inline">
                <span>{{ 'community.filter.tag'|trans }}</span>
                <input type="text" id="filterTag" placeholder="{{ 'community.filter.tag_ph'|trans }}" maxlength="80" pattern="^[a-zA-ZÀ-ÿ0-9_\s\-]*$" title="{{ 'community.validation.tag_pattern'|trans }}" autocomplete="off" />
              </label>
              <label class="field-inline">
                <span>{{ 'community.filter.search_title'|trans }}</span>
                <input type="search" id="searchTitle" placeholder="{{ 'community.filter.search_title_ph'|trans }}" maxlength="120" title="{{ 'js.validation.search_long'|trans }}" autocomplete="off" />
              </label>
              <label class="field-check">
                <input type="checkbox" id="filterMine" />
                <span>{{ 'community.filter.mine'|trans }}</span>
              </label>
            </div>

            <section class="card community-form-card" id="nouveau-post">
              <h2>{{ 'community.form.new_post'|trans }}</h2>
              <p class="form-hint">{{ 'community.form.hint'|trans }}</p>
              <form id="formNewPost" class="stack-form" novalidate>
                <p class="field-error" id="formNewPostError" hidden></p>
                <label>{{ 'community.field.title'|trans }} <input type="text" name="title" required minlength="1" maxlength="255" title="{{ 'community.validation.title_hint'|trans }}" /></label>
                <small class="form-hint">{{ 'community.validation.title_hint'|trans }}</small>
                <label>{{ 'community.field.description'|trans }} <textarea name="description" rows="3" maxlength="10000" title="{{ 'community.validation.desc_hint'|trans }}"></textarea></label>
                <small class="form-hint">{{ 'community.validation.desc_hint'|trans }}</small>
                <label>{{ 'community.field.tag'|trans }} <input type="text" name="tag" maxlength="80" pattern="^[a-zA-ZÀ-ÿ0-9_\s\-]*$" title="{{ 'community.validation.tag_pattern'|trans }}" placeholder="General" /></label>
                <small class="form-hint">{{ 'community.validation.tag_pattern'|trans }}</small>
                <label>{{ 'community.field.image_url'|trans }} <input type="url" name="image_url" maxlength="2048" pattern="https://.*" title="{{ 'community.validation.url_hint'|trans }}" placeholder="https://…" /></label>
                <small class="form-hint">{{ 'community.validation.url_hint'|trans }}</small>
                <button type="submit" class="btn-primary">{{ 'community.field.publish'|trans }}</button>
              </form>
            </section>

            <div id="postsFeed" class="posts-feed" aria-live="polite"></div>
            <p id="feedError" class="feed-error" hidden></p>
          </div>

          <aside class="community-aside community-aside-stack" aria-label="Widgets">
            <div class="card weather-widget" id="weatherWidget" data-weather-err="{{ 'community.weather.error'|trans|e('html_attr') }}">
              <h2 class="aside-title">{{ 'community.weather.title'|trans }}</h2>
              <p class="weather-body" id="weatherBody">{{ 'community.weather.loading'|trans }}</p>
            </div>

            <div class="card chatbot-card">
              <h2 class="aside-title">{{ 'community.chat.title'|trans }}</h2>
              <p class="form-hint">{{ 'community.chat.hint'|trans }}</p>
              <div class="chat-log" id="chatLog" aria-live="polite"></div>
              <form id="chatForm" class="chat-form">
                <label class="sr-only" for="chatInput">{{ 'community.chat.placeholder'|trans }}</label>
                <textarea id="chatInput" rows="2" maxlength="2000" minlength="1" title="{{ 'community.validation.chat_hint'|trans }}" placeholder="{{ 'community.chat.placeholder'|trans }}" required></textarea>
                <small class="form-hint">{{ 'community.validation.chat_hint'|trans }}</small>
                <button type="submit" class="btn-primary">{{ 'community.chat.send'|trans }}</button>
              </form>
            </div>

            <div class="card">
              <h2 class="aside-title">{{ 'community.aside.title'|trans }}</h2>
              <ul class="aside-list">
                <li>{{ 'community.aside.li1'|trans|raw }}</li>
                <li>{{ 'community.aside.li2'|trans|raw }}</li>
                <li>{{ 'community.aside.li3'|trans|raw }}</li>
                <li>{{ 'community.aside.li4'|trans|raw }}</li>
              </ul>
            </div>
          </aside>
        </div>
      </section>
    </main>
  </div>
  <script src="/topNavbar/topNavbar.js"></script>
  <script src="/topNavbar/community-prefs.js"></script>
  <script src="/topNavbar/communaute-app.js"></script>
</body>
</html>
