<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Convocation entretien</title>
</head>
<body style="margin:0; padding:0; background-color:#f3f6fb; font-family:Arial, Helvetica, sans-serif; color:#1f2a37;">
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color:#f3f6fb; padding:24px 12px;">
    <tr>
        <td align="center">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:640px; background-color:#ffffff; border-radius:14px; overflow:hidden; border:1px solid #e5eaf3;">
                <tr>
                    <td style="background:linear-gradient(120deg,#0b4f8a,#2563eb); padding:26px 28px;">
                        <p style="margin:0; color:#dce9ff; font-size:12px; letter-spacing:0.08em; text-transform:uppercase;">HR-One</p>
                        <h1 style="margin:10px 0 0; color:#ffffff; font-size:24px; line-height:1.3;">Convocation a un entretien</h1>
                    </td>
                </tr>

                <tr>
                    <td style="padding:26px 28px 10px;">
                        <p style="margin:0 0 14px; font-size:16px; line-height:1.6;">Bonjour {{ candidateName|default('Candidat') }},</p>
                        <p style="margin:0; font-size:15px; line-height:1.7; color:#354052;">
                            Votre entretien pour le poste <strong>{{ offerTitle|default('Poste') }}</strong> est planifie.
                        </p>
                    </td>
                </tr>

                <tr>
                    <td style="padding:10px 28px 0;">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="border:1px solid #d9e3f5; border-radius:12px; background-color:#f8fbff;">
                            <tr>
                                <td style="padding:16px 18px; font-size:14px; color:#1f2a37; border-bottom:1px solid #e4ecf8;">
                                    <strong style="display:inline-block; min-width:82px; color:#0b4f8a;">Date</strong>
                                    <span>{{ interviewDate|default('Date a confirmer') }}</span>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:16px 18px; font-size:14px; color:#1f2a37; border-bottom:1px solid #e4ecf8;">
                                    <strong style="display:inline-block; min-width:82px; color:#0b4f8a;">Heure</strong>
                                    <span>{{ interviewTime|default('Heure a confirmer') }}</span>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:16px 18px; font-size:14px; color:#1f2a37;">
                                    <strong style="display:inline-block; min-width:82px; color:#0b4f8a;">Lieu</strong>
                                    <span>{{ interviewLocation|default('A definir') }}</span>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <tr>
                    <td style="padding:20px 28px 24px;">
                        <p style="margin:0; font-size:14px; color:#1f2a37;">Cordialement,<br><strong>Equipe RH - HR-One</strong></p>
                    </td>
                </tr>

                <tr>
                    <td style="padding:14px 28px; background-color:#f6f8fc; border-top:1px solid #e8edf6;">
                        <p style="margin:0; font-size:12px; color:#667085; line-height:1.6;">
                            Cet email a ete envoye automatiquement par HR-One.
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
