# Copy this file to .env.local and fill the values.
# .env.local has priority over .env and should never be committed with secrets.

# --- AI (Groq) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- Mailer (SMTP) ---
# Gmail example (app password required):
# MAILER_DSN=smtp://your_email@gmail.com:your_app_password@smtp.gmail.com:587?encryption=tls&auth_mode=login
# Mailtrap example:
# MAILER_DSN=smtp://username:password@sandbox.smtp.mailtrap.io:2525
MAILER_DSN=null://null

# Sender identity used by CandidateNotificationService
MAILER_FROM_EMAIL=hrone@local.test
MAILER_FROM_NAME="HR One"
